<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudySnap - 勉強を記録して、仲間と頑張る</title>
    <meta name="description" content="StudySnapは、勉強をランダム撮影して記録し、グループで共有・承認し合うことで学習習慣を定着させる学習管理アプリです。">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', sans-serif;
            color: #1d1d1f;
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 16px 24px;
            backdrop-filter: blur(20px);
            background: rgba(255,255,255,0.85);
            border-bottom: 1px solid rgba(0,0,0,0.06);
        }
        .nav-inner {
            max-width: 960px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .nav-logo {
            font-size: 20px;
            font-weight: 700;
            color: #1d1d1f;
            text-decoration: none;
        }
        .nav-links {
            display: flex;
            gap: 24px;
        }
        .nav-links a {
            font-size: 14px;
            color: #424245;
            text-decoration: none;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: #6366f1; }

        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 120px 24px 80px;
            background: linear-gradient(180deg, #f5f5f7 0%, #e8e5fb 50%, #d4cffa 100%);
            position: relative;
        }
        .hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 120px;
            background: linear-gradient(to bottom, transparent, #fff);
        }
        .hero-content {
            max-width: 640px;
            position: relative;
            z-index: 1;
        }
        .hero-icon {
            width: 88px;
            height: 88px;
            border-radius: 22px;
            background: linear-gradient(135deg, #6366f1, #818cf8);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 32px;
            box-shadow: 0 12px 40px rgba(99, 102, 241, 0.3);
        }
        .hero-icon svg {
            width: 44px;
            height: 44px;
            fill: #fff;
        }
        .hero h1 {
            font-size: clamp(36px, 6vw, 56px);
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.15;
            margin-bottom: 16px;
        }
        .hero h1 span {
            background: linear-gradient(135deg, #6366f1, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero p {
            font-size: 18px;
            color: #424245;
            margin-bottom: 36px;
            line-height: 1.8;
        }
        .app-store-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #1d1d1f;
            color: #fff;
            padding: 14px 28px;
            border-radius: 14px;
            text-decoration: none;
            font-size: 16px;
            font-weight: 600;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .app-store-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.2);
        }
        .app-store-btn svg {
            width: 24px;
            height: 24px;
            fill: #fff;
        }

        .features {
            padding: 100px 24px;
            background: #fff;
        }
        .features-inner {
            max-width: 960px;
            margin: 0 auto;
        }
        .features h2 {
            font-size: 32px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }
        .features .subtitle {
            text-align: center;
            color: #86868b;
            font-size: 16px;
            margin-bottom: 64px;
        }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }
        .feature-card {
            background: #f5f5f7;
            border-radius: 20px;
            padding: 36px 28px;
            transition: transform 0.2s;
        }
        .feature-card:hover {
            transform: translateY(-4px);
        }
        .feature-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 20px;
        }
        .feature-card h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .feature-card p {
            font-size: 15px;
            color: #424245;
            line-height: 1.7;
        }

        .how-it-works {
            padding: 100px 24px;
            background: #f5f5f7;
        }
        .how-inner {
            max-width: 720px;
            margin: 0 auto;
        }
        .how-it-works h2 {
            font-size: 32px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 60px;
            letter-spacing: -0.5px;
        }
        .step {
            display: flex;
            gap: 24px;
            margin-bottom: 48px;
            align-items: flex-start;
        }
        .step-num {
            width: 48px;
            height: 48px;
            min-width: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .step h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .step p {
            font-size: 15px;
            color: #424245;
            line-height: 1.7;
        }

        .cta {
            padding: 100px 24px;
            background: linear-gradient(135deg, #1e1b4b, #312e81);
            text-align: center;
            color: #fff;
        }
        .cta h2 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 12px;
        }
        .cta p {
            font-size: 16px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 36px;
        }
        .cta .app-store-btn {
            background: #fff;
            color: #1d1d1f;
        }
        .cta .app-store-btn svg { fill: #1d1d1f; }

        .footer {
            padding: 40px 24px;
            background: #1d1d1f;
            text-align: center;
        }
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 24px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .footer-links a {
            font-size: 14px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-links a:hover { color: #fff; }
        .footer p {
            font-size: 13px;
            color: rgba(255,255,255,0.4);
        }

        @media (max-width: 600px) {
            .nav-links { gap: 16px; }
            .features-grid { grid-template-columns: 1fr; }
            .step { flex-direction: column; gap: 12px; }
        }
    </style>
</head>
